+// F11: scan the accumulated IEC61937 stream (p->spdif_acc) for complete data-bursts and copy each
+// burst's bare frame into p->spdif_out, de-byte-swapped. ad_spdif feeds us IEC61937 bursts even in
+// RAW mode, and mpv's audio chunks are NOT burst-aligned, so we keep a carry across writes. Burst:
+// 4x 16-bit preamble (Pa=0xF872, Pb=0x4E1F, Pc, Pd=length-in-bits), payload, zero padding to the
+// repetition period. spdifenc emits 16-bit big-endian by default, so the sync arrives byte-swapped
+// (0x72F8/0x1F4E); we detect both orders and unswap the payload accordingly. Returns bytes in out.
+static int iec61937_extract(struct ao *ao)
+{
+    struct priv *p = ao->priv;
+    uint8_t *a = p->spdif_acc;
+    int n = p->spdif_acc_len;
+    int out = 0;
+    int i = 0;
+    while (i + 8 <= n) {
+        uint16_t w0 = a[i] | (a[i + 1] << 8);
+        uint16_t w1 = a[i + 2] | (a[i + 3] << 8);
+        bool be = (w0 == 0x72F8 && w1 == 0x1F4E); // spdifenc big-endian (payload byte-swapped)
+        bool le = (w0 == 0xF872 && w1 == 0x4E1F); // little-endian (payload already native)
+        if (!be && !le) { i += 2; continue; }     // IEC61937 is 16-bit aligned → scan by words
+        uint16_t pd = a[i + 6] | (a[i + 7] << 8);
+        if (be) pd = (pd << 8) | (pd >> 8);
+        int payload = (pd + 7) / 8;
+        if (payload <= 0 || out + payload > p->spdif_acc_cap) { i += 2; continue; }
+        if (i + 8 + payload > n) break;           // burst not fully accumulated yet
+        uint8_t *src = a + i + 8;
+        if (be) {
+            for (int k = 0; k + 1 < payload; k += 2) {
+                p->spdif_out[out + k]     = src[k + 1];
+                p->spdif_out[out + k + 1] = src[k];
+            }
+            if (payload & 1) p->spdif_out[out + payload - 1] = src[payload - 1];
+        } else {
+            memcpy(p->spdif_out + out, src, payload);
+        }
+        out += payload;
+        i += 8 + payload; // padding (zeros) up to the next sync is skipped by the scan above
+    }
+    int rem = n - i;
+    memmove(a, a + i, rem);
+    p->spdif_acc_len = rem;
+    return out;
+}
