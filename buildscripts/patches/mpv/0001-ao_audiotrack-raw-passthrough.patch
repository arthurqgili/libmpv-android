+// F11: extract the bare compressed frame from an IEC 61937 data-burst, in place. ad_spdif feeds us
+// the burst (PCM-shaped) even for RAW passthrough; ENCODING_AC3/E_AC3/DTS want the naked frame.
+// Burst layout: 4x 16-bit preamble (Pa=0xF872, Pb=0x4E1F, Pc=type, Pd=length-in-bits), then the
+// payload (16-bit byte-swapped by spdifenc), then zero padding to the repetition period.
+// Returns the payload length in bytes, 0 if the burst carries none, or -1 if no valid sync.
+static int iec61937_unwrap(struct ao *ao, void *buf, int len)
+{
+    if (len < 8)
+        return -1;
+    uint16_t *w = buf;
+    if (w[0] != 0xF872 || w[1] != 0x4E1F) {
+        MP_VERBOSE(ao, "iec61937: no sync (w0=%04x w1=%04x)\n", w[0], w[1]);
+        return -1;
+    }
+    int payload_bytes = (w[3] + 7) / 8;
+    if (payload_bytes <= 0)
+        return 0;
+    if (payload_bytes > len - 8)
+        payload_bytes = len - 8;
+    uint8_t *payload = (uint8_t *)buf + 8;
+    // spdifenc emits the payload byte-swapped (16-bit); restore the codec's native byte order.
+    for (int i = 0; i + 1 < payload_bytes; i += 2) {
+        uint8_t t = payload[i]; payload[i] = payload[i + 1]; payload[i + 1] = t;
+    }
+    memmove(buf, payload, payload_bytes);
+    return payload_bytes;
+}
